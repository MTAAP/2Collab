{
  "name": "2collab",
  "version": "0.1.0",
  "private": true,
  "description": "A self-hosted coordination surface for small developer teams and their local agent runtimes.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "start": "bun dist/server/index.js",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "clean": "bun run scripts/clean.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test tests/unit tests/integration tests/protocol tests/runner tests/drills",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:protocol": "bun test tests/protocol",
    "test:runner": "bun test tests/runner",
    "test:e2e": "bun run clean && bun run build:web && bun run build:server && bun run test:e2e:run",
    "test:e2e:run": "playwright test",
    "build": "bun run clean && bun run build:web && bun run build:server && bun run build:cli",
    "build:web": "vite build",
    "build:server": "bun build src/server/index.ts --target bun --outdir dist/server",
    "build:cli": "bun build --compile src/cli/index.ts --outfile dist/collab",
    "audit:public": "bun run scripts/audit-public.ts",
    "archive": "bun run scripts/archive.ts",
    "archive:verify": "bun run scripts/verify-archive.ts",
    "manifest:generate": "bun run scripts/manifest.ts generate",
    "manifest:verify": "bun run scripts/manifest.ts verify",
    "evidence:verify": "bun run scripts/verify-evidence.ts",
    "evidence:validate": "bun run scripts/foundation-evidence.ts validate",
    "evidence:foundation-exit": "bun run scripts/foundation-evidence.ts check-exit",
    "verify": "bun ci && bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build && bun run test:e2e:run && bun run audit:public && bun run manifest:verify && bun run archive:verify && bun run evidence:verify && bun run evidence:validate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@simplewebauthn/server": "13.3.2",
    "@xyflow/react": "12.11.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "hono": "4.12.29",
    "lucide-react": "1.24.0",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  }
}
