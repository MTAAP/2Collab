# Network binding for the collab-server in local development.
HOST=127.0.0.1
PORT=3210

# Use production only behind a trusted HTTPS ingress.
NODE_ENV=development

# Replace in production with at least 32 random characters.
# This is not a secret file; it is an environment variable.
SESSION_SECRET=replace-with-a-random-production-secret

# Public origin and WebAuthn relying-party ID for the deployment.
PUBLIC_BASE_URL=http://localhost:3210
WEBAUTHN_RP_ID=localhost

# Paths to the mounted secret files used in container deployments.
# These files must be generated outside of this example and mounted read-only.
DEPLOYMENT_MASTER_KEY_FILE=./.secrets/deployment-master-key
BOOTSTRAP_SECRET_FILE=./.secrets/bootstrap-secret

# Optional passwordless email OTP delivery. Configure both or neither.
# In production the API key path must be absolute and mounted read-only with mode 0600.
# RESEND_API_KEY_FILE=/run/secrets/resend_api_key
# AUTH_EMAIL_FROM=auth@example.com

# Persistent directories. In Docker these are named volumes.
DATA_DIR=./data
BACKUP_DIR=./backups
